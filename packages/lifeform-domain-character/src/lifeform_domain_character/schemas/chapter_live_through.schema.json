{
  "type": "object",
  "additionalProperties": false,
  "required": ["chapters"],
  "properties": {
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chapter_id",
          "chapter_index",
          "chapter_title",
          "coverage",
          "evidence_locator",
          "epistemic_cutoff_locator",
          "known_facts",
          "excluded_facts",
          "scenes",
          "semantic_events"
        ],
        "properties": {
          "chapter_id": { "type": "string" },
          "chapter_index": { "type": "integer", "minimum": 0 },
          "chapter_title": { "type": "string" },
          "coverage": {
            "type": "string",
            "enum": ["experienced", "learned", "not-known", "no-change"]
          },
          "evidence_locator": { "type": "string" },
          "epistemic_cutoff_locator": { "type": "string" },
          "known_facts": { "type": "array", "items": { "type": "string" } },
          "excluded_facts": { "type": "array", "items": { "type": "string" } },
          "scenes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "scene_id",
                "phase_label",
                "setting",
                "decision_point",
                "canonical_action",
                "canonical_outcome",
                "emotional_register",
                "evidence_locator"
              ],
              "properties": {
                "scene_id": { "type": "string" },
                "phase_label": {
                  "type": "string",
                  "enum": ["child", "adolescent", "mature", "elder"]
                },
                "setting": { "type": "string" },
                "decision_point": { "type": "string" },
                "canonical_action": { "type": "string" },
                "canonical_outcome": { "type": "string" },
                "emotional_register": {
                  "type": "string",
                  "enum": [
                    "calm",
                    "warm",
                    "tense",
                    "crisis",
                    "grief",
                    "joy",
                    "shame",
                    "resolve",
                    "doubt",
                    "wonder"
                  ]
                },
                "risk_markers": { "type": "array", "items": { "type": "string" } },
                "expected_regime": { "type": ["string", "null"] },
                "evidence_locator": { "type": "string" }
              }
            }
          },
          "semantic_events": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "event_id",
                "target_slot",
                "operation",
                "summary",
                "detail",
                "confidence",
                "evidence_locator"
              ],
              "properties": {
                "event_id": { "type": "string" },
                "target_slot": {
                  "type": "string",
                  "enum": [
                    "plan_intent",
                    "commitment",
                    "open_loop",
                    "user_model",
                    "execution_result",
                    "belief_assumption",
                    "relationship_state",
                    "goal_value",
                    "boundary_consent"
                  ]
                },
                "operation": {
                  "type": "string",
                  "enum": [
                    "observe",
                    "create",
                    "revise",
                    "defer",
                    "activate",
                    "complete",
                    "close",
                    "block"
                  ]
                },
                "summary": { "type": "string" },
                "detail": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "evidence_locator": { "type": "string" },
                "control_signal": { "type": "number" },
                "requires_confirmation": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
