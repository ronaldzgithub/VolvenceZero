{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vz://schemas/growth-advisor/archetype-classification.v0.json",
  "title": "GrowthAdvisorArchetypeClassification",
  "description": "Schema enforced when parsing LLMArchetypeClassifier output. See packages/lifeform-domain-growth-advisor/src/lifeform_domain_growth_advisor/archetype_classifier.py.",
  "type": "object",
  "required": ["primary", "probabilities", "confidence"],
  "additionalProperties": false,
  "properties": {
    "primary": {
      "type": "string",
      "enum": ["anxious", "comparing", "standard_seeking", "venting", "product_seeking"]
    },
    "probabilities": {
      "type": "object",
      "required": ["anxious", "comparing", "standard_seeking", "venting", "product_seeking"],
      "additionalProperties": false,
      "properties": {
        "anxious": {"type": "number", "minimum": 0, "maximum": 1},
        "comparing": {"type": "number", "minimum": 0, "maximum": 1},
        "standard_seeking": {"type": "number", "minimum": 0, "maximum": 1},
        "venting": {"type": "number", "minimum": 0, "maximum": 1},
        "product_seeking": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "rationale": {"type": "string"}
  }
}
