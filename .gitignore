# Figure-vertical L1 cleaning store: raw bytes & cleaned text are
# generated artefacts (debt #28 L1). The data/ directory itself is
# tracked via a .gitkeep marker so the path is stable; subtrees are
# not versioned.
packages/lifeform-domain-figure/data/raw/
packages/lifeform-domain-figure/data/cleaned/

# Figure-vertical L2 verification ledger: per-anchor checks.jsonl is a
# generated audit artefact (debt #28 L2). Same treatment as L1 raw/
# cleaned trees.
packages/lifeform-domain-figure/data/verification/

# Figure-vertical L0 crawler frontier + results: per-run queue.jsonl /
# visited.jsonl / results.jsonl are generated artefacts (debt #28 L0).
packages/lifeform-domain-figure/data/crawl/

# Figure-vertical CLI bake / audit artefacts (debt #23 closure).
# The CLI defaults persist bundles to data/figure_bundles/ and audit
# rows to data/figure_audit/; both are runtime products, not source.
data/figure_bundles/
data/figure_audit/

# Figure-vertical real-corpus collection (Wave K). Repo-root data/
# figure_corpus/ holds the L0 frontier + L1 raw/cleaned + L2
# verification ledger for live runs of scripts/figure_collect_einstein.sh.
# Curator-tracked seed lists + metadata files live under
# packages/lifeform-domain-figure/data/seeds/ which IS in git.
data/figure_corpus/

# External benchmark harnesses + their run artefacts (debt #29).
# The eqbench3 / empathybench harnesses are cloned (or git-submoduled
# in a future packet) into external/<harness>/ so we keep our
# adapter clean and let upstream evolve. Their checkouts and the
# scoring outputs do not belong in our git history. The parent
# directories are tracked via .gitkeep so the paths are stable in
# fresh clones.
external/eqbench3/
external/empathybench/
artifacts/external_bench/*
!artifacts/external_bench/.gitkeep

# Companion Bench held-out scenarios live in a SEPARATE private
# repository (`companionbench/heldout`) and are pulled in as a git
# submodule at external/companionbench-heldout/. The public monorepo
# MUST NOT see the held-out YAML in any commit diff (RFC §3 P3, §8.6).
# The .gitmodules entry references the private repo; the actual
# checkout is gitignored so accidental file drops never enter the
# public history.
artifacts/companionbench/*
!artifacts/companionbench/.gitkeep
artifacts/companion-bench/*
!artifacts/companion-bench/.gitkeep
artifacts/companion_bench_smoke/*
!artifacts/companion_bench_smoke/.gitkeep
/.local
/.local
