# EQ-Bench 3 / EmpathyBench harness environment.
#
# Copy this file to external/eqbench3/.env (and external/empathybench/.env
# if you also run that harness) and fill in the JUDGE_API_KEY value
# before running scripts/external_bench/run_eqbench3.py.
#
# Three-track architecture: TEST_API_URL is the OpenAI-compat URL we
# expose on each ablation track — the runner sets this per-track.
# JUDGE_API_KEY is what the harness uses to score transcripts via
# Claude Sonnet 3.7 (or the alternate judge you choose).

# Test model — per-track URL. The runner overrides these per track;
# the values here are illustrative defaults for manual single-track
# runs. NOTE: eqbench3's APIClient expects TEST_API_URL to be the
# FULL chat-completions endpoint — do NOT trim the path to /v1.
TEST_API_URL=http://127.0.0.1:8770/v1/chat/completions
TEST_API_KEY=lifeform-openai-compat-no-auth

# Judge — Anthropic by default (matches EQ-Bench 3 reference).
# To use OpenRouter / OpenAI / a self-hosted judge, change the URL
# AND make sure your harness fork supports the judge's wire format.
# Same URL semantics as TEST_API_URL: full chat-completions path.
JUDGE_API_URL=https://api.anthropic.com/v1/chat/completions
JUDGE_API_KEY=sk-ant-REPLACE-ME

# Optional: harness-side timeouts.
TEST_TIMEOUT=300
JUDGE_TIMEOUT=300
