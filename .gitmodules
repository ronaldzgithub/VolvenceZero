[submodule "external/companionbench-heldout"]
	path = external/companionbench-heldout
	url = git@github.com:companionbench/heldout.git
	branch = main
	# Companion Bench held-out scenario set (RFC §3 P3 / §8.6).
	#
	# The submodule mounts the PRIVATE companionbench/heldout repository.
	# CI uses a deploy key and only nightly / release workflows check it
	# out. Public contributors who clone VolvenceZero may see the path
	# referenced here but cannot fetch the contents — that is by design.
	# The harness in packages/companion-bench detects the missing
	# directory and runs against public scenarios only.

[submodule "research"]
	path = research
	url = https://github.com/ronaldzgithub/volvence-research.git
	branch = main
	# Paper PDFs, probe corpora, and research notes. PRIVATE: clone with
	# credentials or deploy key; contributors without access skip submodule init.
[submodule "external/vz-bundle"]
	path = external/vz-bundle
	url = https://github.com/ronaldzgithub/vz-bundle.git
	branch = main
